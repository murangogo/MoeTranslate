<!--
   PaddleOCR PP-OCRv6_small 可识别的源语言。
   单模型单字典覆盖中/繁/日/英及拉丁系文字，但字典中无韩文（故不含 ko）、无西里尔字母（故不含 ru）。
   这里仅列出「识别字典支持 且 各翻译引擎也普遍支持」的常用语言，保证 OCR→翻译 全链路可用。
-->
<languages>
    <language>
        <code>zh</code>
    </language>
    <language>
        <code>en</code>
    </language>
    <language>
        <code>ja</code>
    </language>
    <language>
        <code>fr</code>
    </language>
    <language>
        <code>de</code>
    </language>
    <language>
        <code>es</code>
    </language>
    <language>
        <code>it</code>
    </language>
    <language>
        <code>pt</code>
    </language>
</languages>
