<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 总开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/translation_history_switch_label"
                android:textColor="#444"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 附加提示词 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/translation_history_prompt_label"
            android:textColor="#444"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edit_history_prompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/edittext_api"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="5"
            android:padding="10dp"
            android:textColor="#222"
            android:textSize="13sp" />

        <!-- 历史翻译记录条数 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/translation_history_count_label"
            android:textColor="#444"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edit_history_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/edittext_api"
            android:inputType="number"
            android:maxLines="1"
            android:padding="10dp"
            android:textColor="#222"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
